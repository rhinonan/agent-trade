# 服务端口（SaaS 代理模式下设为 3001，默认 3000）
# PORT=3001

# LLM API Key (根据 provider 选择)
# deepseek / openai: 设置 OPENAI_API_KEY
# anthropic: 设置 ANTHROPIC_API_KEY
OPENAI_API_KEY=sk-your-key-here

# 火山引擎联网搜索 API Key（从 https://console.volcengine.com/search-infinity/api-key 获取）
WEB_SEARCH_API_KEY=

# WebSocket URL for client-side Socket.IO connections.
# Set this when running behind the SaaS proxy so the browser connects directly
# to the open-source server's WebSocket port.
# NEXT_PUBLIC_WS_URL=http://localhost:3001

# Log level: "error" | "warn" | "info" | "debug" | "verbose"
# - error: only critical failures
# - warn:  warnings + errors
# - info:  lifecycle events (default in development)
# - debug: detailed workflow/node transitions, LLM provider/model selection
# - verbose: full LLM prompts, responses, token counts, and timing
# In production, defaults to "warn" unless explicitly set.
LOG_LEVEL=info


